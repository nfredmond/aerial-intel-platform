NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AERIAL_DISPATCH_ADAPTER_URL=https://dispatch.example.com/launch
AERIAL_DISPATCH_ADAPTER_LABEL=NodeODM dispatch webhook
AERIAL_DISPATCH_ADAPTER_TOKEN=replace-me-if-needed
AERIAL_DISPATCH_CALLBACK_TOKEN=replace-me-if-you-want-a-dedicated-inbound-token
# Optional: NodeODM direct dispatch (used when dispatchMode="nodeodm-direct"; falls back to webhook adapter if unset)
AERIAL_NODEODM_URL=http://localhost:3001
AERIAL_NODEODM_TOKEN=
# Optional: set to "stub" for CI/dev to use an in-memory NodeODM stub (default "real"). Never set to "stub" in production.
AERIAL_NODEODM_MODE=real
# Shared secret for internal cron routes (proving-heartbeat, nodeodm-upload, nodeodm-poll)
CRON_SECRET=replace-with-a-long-random-string
# Optional: log level for structured JSON logger (debug|info|warn|error)
AERIAL_LOG_LEVEL=info
# Optional: MapLibre basemap overrides (defaults to OSM vector + satellite)
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=
NEXT_PUBLIC_MAPLIBRE_SATELLITE_URL=
# Optional: TiTiler service URL for the /artifacts/[artifactId] raster viewer.
# Leave unset to suppress the in-page viewer (users see a "viewer not configured" card).
# Dev default points at the opengeo-titiler container on this host; production should run
# a separate TiTiler service behind a CDN. See docs/ops/titiler-setup.md.
AERIAL_TITILER_URL=http://localhost:8000
# Aerial Copilot (Wave 2 — narrow grounded AI-assist). See docs/ADR/ADR-002-aerial-copilot.md.
# Global kill-switch; still requires per-org opt-in via drone_org_settings.copilot_enabled.
AERIAL_COPILOT_ENABLED=false
# Default per-org monthly spend cap seeded into drone_org_ai_quota (tenth-cents). 50000 = $50.
AERIAL_COPILOT_DEFAULT_CAP_TENTH_CENTS=50000
# Server-side only — never exposed to the browser. Required when AERIAL_COPILOT_ENABLED=true.
# On Vercel, OIDC auth (VERCEL_OIDC_TOKEN) is auto-injected and takes precedence; set the
# key explicitly for local dev or non-Vercel deployments.
AI_GATEWAY_API_KEY=
